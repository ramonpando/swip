---
const navLinks = [
  { href: '/como-funciona/', label: 'Cómo funciona' },
  { href: '/vehiculos-que-aceptamos/', label: 'Vehículos' },
  { href: '/requisitos/', label: 'Requisitos' },
  { href: '/blog/', label: 'Blog' },
];

const currentPath = Astro.url.pathname;
---
<nav>
  <a href="/" class="nav-logo">
    <img src="/assets/logos/logo-light.svg" alt="SWIP" height="28" />
  </a>
  <div class="nav-links" id="nav-links">
    {navLinks.map(link => (
      <a
        href={link.href}
        class:list={[{ active: currentPath.startsWith(link.href) }]}
      >
        {link.label}
      </a>
    ))}
    <a href="/cotizar/" class="nav-mobile-cta">Cotiza tu préstamo</a>
  </div>
  <div class="nav-right">
    <a href="/cotizar/" class="nav-cta">Cotiza tu préstamo</a>
    <button class="nav-hamburger" id="nav-hamburger" aria-label="Menú" aria-expanded="false" aria-controls="nav-links">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<style>
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 56px;
    background: rgba(10, 10, 10, 0.96);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-top: 1px solid var(--green-dim);
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    overflow: visible;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .nav-links {
    display: flex;
    gap: 40px;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  .nav-links a {
    font-size: 11px;
    letter-spacing: 0.22em;
    color: rgba(168, 168, 168, 0.56);
    text-decoration: none;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--white);
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .nav-mobile-cta {
    display: none;
  }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    letter-spacing: 0.24em;
    color: rgba(255, 255, 255, 0.74);
    text-decoration: none;
    text-transform: uppercase;
    transition: color 0.2s, transform 0.2s;
    white-space: nowrap;
  }

  .nav-cta::after {
    content: '→';
    font-size: 14px;
    line-height: 1;
    transition: transform 0.2s;
  }

  .nav-cta:hover {
    color: var(--white);
    transform: translateX(2px);
  }

  .nav-cta:hover::after {
    transform: translateX(4px);
  }

  .nav-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .nav-hamburger span {
    display: block;
    width: 22px;
    height: 1px;
    background: var(--silver);
    transition: all 0.25s;
  }

  .nav-hamburger.open span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
  .nav-hamburger.open span:nth-child(2) { opacity: 0; }
  .nav-hamburger.open span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

  @media (max-width: 768px) {
    nav { padding: 18px 24px; }
    .nav-links {
      position: absolute;
      top: calc(100% + 1px);
      left: -24px;
      right: -24px;
      display: flex;
      flex-direction: column;
      align-items: stretch;
      justify-content: flex-start;
      gap: 0;
      padding: 18px 0 32px;
      min-height: calc(100dvh - 62px);
      max-height: calc(100dvh - 62px);
      background:
        linear-gradient(180deg, rgba(14, 14, 14, 0.995) 0%, rgba(10, 10, 10, 0.985) 100%);
      border-top: 1px solid rgba(255, 255, 255, 0.06);
      border-bottom: 1px solid var(--line);
      transform: none;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      overflow-y: auto;
      transition: opacity 0.22s ease, visibility 0.22s ease;
      z-index: 120;
    }
    .nav-links.open {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
    }
    .nav-links a {
      display: block;
      padding: 18px 24px;
      font-size: 13px;
      letter-spacing: 0.18em;
      color: rgba(255, 255, 255, 0.84);
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }
    .nav-links a.active {
      color: var(--white);
      background: rgba(255, 255, 255, 0.03);
    }
    .nav-mobile-cta {
      display: block;
      margin: 18px 24px 0;
      padding: 16px 18px;
      border: 1px solid rgba(255, 255, 255, 0.2);
      color: var(--white);
      background: rgba(255, 255, 255, 0.04);
      text-align: center;
    }
    .nav-cta { display: none; }
    .nav-hamburger { display: flex; }
  }
</style>

<script>
  const hamburger = document.getElementById('nav-hamburger');
  const navLinks  = document.getElementById('nav-links');
  hamburger?.addEventListener('click', () => {
    const isOpen = hamburger.classList.toggle('open');
    navLinks?.classList.toggle('open', isOpen);
    hamburger.setAttribute('aria-expanded', String(isOpen));
    document.body.style.overflow = isOpen ? 'hidden' : '';
  });

  navLinks?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      hamburger?.classList.remove('open');
      navLinks.classList.remove('open');
      hamburger?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    });
  });
</script>
