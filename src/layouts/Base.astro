---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  ogType?: string;
  publishedTime?: string;
  modifiedTime?: string;
  schema?: object | object[];
}

const {
  title,
  description,
  canonical,
  ogImage = 'https://swip.mx/assets/og-default.jpg',
  noindex = false,
  ogType = 'website',
  publishedTime,
  modifiedTime,
  schema,
} = Astro.props;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, 'https://swip.mx').href;
const baseSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://swip.mx/#organization",
      "name": "SWIP",
      "legalName": "CORPOSWIP LATAM, S.A.P.I. DE C.V.",
      "url": "https://swip.mx",
      "logo": "https://swip.mx/assets/logos/logo-light.svg",
      "description": "Liquidez inteligente con respaldo en tu auto. Préstamos con garantía vehicular para autos de lujo, blindados y vehículos de alto valor en México.",
      "email": "patricia_bernal@swip.mx",
      "telephone": "+52-1-55-5405-5089",
      "sameAs": [
        "https://wa.me/5215554055089"
      ]
    },
    {
      "@type": "FinancialService",
      "@id": "https://swip.mx/#financial-service",
      "name": "SWIP",
      "url": "https://swip.mx",
      "image": "https://swip.mx/assets/og-default.jpg",
      "description": "Préstamos con garantía vehicular para autos de lujo, blindados y vehículos de alto valor en México.",
      "currenciesAccepted": "MXN",
      "priceRange": "$$$$",
      "paymentAccepted": "Transferencia bancaria",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Pje. Interlomas 6",
        "addressLocality": "Naucalpan de Juárez",
        "addressRegion": "Estado de México",
        "postalCode": "52787",
        "addressCountry": "MX"
      },
      "areaServed": [
        {
          "@type": "City",
          "name": "Ciudad de México",
          "sameAs": "https://www.wikidata.org/wiki/Q1489"
        },
        {
          "@type": "City",
          "name": "Querétaro",
          "sameAs": "https://www.wikidata.org/wiki/Q16572"
        }
      ],
      "serviceArea": [
        { "@type": "City", "name": "Ciudad de México" },
        { "@type": "City", "name": "Querétaro" }
      ],
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": [
            "Monday",
            "Tuesday",
            "Wednesday",
            "Thursday",
            "Friday"
          ],
          "opens": "09:00",
          "closes": "19:00"
        }
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+52-1-55-5405-5089",
        "email": "patricia_bernal@swip.mx",
        "contactType": "sales",
        "areaServed": "MX",
        "availableLanguage": [
          "es",
          "es-MX"
        ]
      },
      "parentOrganization": {
        "@id": "https://swip.mx/#organization"
      }
    },
    {
      "@type": "WebSite",
      "@id": "https://swip.mx/#website",
      "url": "https://swip.mx",
      "name": "SWIP",
      "inLanguage": "es-MX",
      "publisher": {
        "@id": "https://swip.mx/#organization"
      }
    }
  ]
};
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="google-site-verification" content="nDe7eVG7YPXxzVl-mwhXLGCq6Hcjpla7mFxkSP47jKs" />

  <!-- Google Tag Manager -->
  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-N7GP6M25');</script>
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content="SWIP" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content="es_MX" />
  {publishedTime && <meta property="article:published_time" content={publishedTime} />}
  {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Schema base: Organization -->
  <script type="application/ld+json" set:html={JSON.stringify(baseSchema)} />

  <!-- Schema adicional por página -->
  {schema && (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )}

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/assets/logos/favicon.svg" />

  <!-- Fonts — async to avoid render blocking -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@300;400;500&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@300;400;500&display=swap" /></noscript>
  <slot name="head" />

</head>
<body>
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-N7GP6M25"
  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <slot />
  <script is:inline>
    (function() {
      const params = new URLSearchParams(window.location.search);
      if (params.get('utm_medium') !== 'cpc' && !params.has('gclid')) return;
      const msg = encodeURIComponent('Hola, vi su anuncio y me interesa el préstamo con garantía de auto');
      document.querySelectorAll('a[href*="wa.me"]').forEach(function(a) {
        a.href = a.href.replace(/[?&]text=[^&]*/, '') + (a.href.includes('?') ? '&' : '?') + 'text=' + msg;
      });
    })();
  </script>
  <!-- Modal de cotización -->
  <div id="swip-modal-overlay" style="display:none" aria-modal="true" role="dialog">
    <div id="swip-modal">
      <button id="swip-modal-close" aria-label="Cerrar">×</button>
      <p class="swip-modal-eyebrow">¿CÓMO QUIERES CONTINUAR?</p>
      <div class="swip-modal-options">
        <div class="swip-modal-option">
          <p class="swip-option-label">Sin compromiso</p>
          <h3 class="swip-option-title">Cotiza con SwipBot</h3>
          <p class="swip-option-body">El bot te hace 3 preguntas y estima cuánto puedes obtener. Sin presión, sin asesor.</p>
          <button class="swip-btn-bot" id="swip-open-bot">Iniciar chat →</button>
        </div>
        <div class="swip-modal-divider"></div>
        <div class="swip-modal-option">
          <p class="swip-option-label">Respuesta inmediata</p>
          <h3 class="swip-option-title">Hablar con un asesor</h3>
          <p class="swip-option-body">Un asesor real te atiende ahora por WhatsApp. Para cuando ya sabes que quieres avanzar.</p>
          <a class="swip-btn-wa" id="swip-open-wa" href="https://wa.me/5215554055089?text=Hola%2C%20quiero%20cotizar%20un%20pr%C3%A9stamo%20con%20garant%C3%ADa%20de%20mi%20veh%C3%ADculo" target="_blank" rel="noopener">Abrir WhatsApp →</a>
        </div>
      </div>
    </div>
  </div>

  <style>
    #swip-modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.85);
      z-index: 99999;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }
    #swip-modal {
      background: #0a0a0a;
      border: 1px solid rgba(255,255,255,0.1);
      max-width: 720px;
      width: 100%;
      padding: 56px 48px;
      position: relative;
    }
    #swip-modal-close {
      position: absolute;
      top: 20px;
      right: 24px;
      background: none;
      border: none;
      color: rgba(255,255,255,0.4);
      font-size: 24px;
      cursor: pointer;
      line-height: 1;
      padding: 0;
    }
    #swip-modal-close:hover { color: #fff; }
    .swip-modal-eyebrow {
      font-size: 9px;
      letter-spacing: 0.42em;
      color: rgba(168,168,168,0.38);
      text-transform: uppercase;
      margin: 0 0 40px;
      text-align: center;
    }
    .swip-modal-options {
      display: grid;
      grid-template-columns: 1fr 1px 1fr;
      gap: 40px;
    }
    .swip-modal-divider {
      background: rgba(255,255,255,0.08);
    }
    .swip-modal-option {
      display: flex;
      flex-direction: column;
    }
    .swip-option-label {
      font-size: 9px;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      color: rgba(168,168,168,0.38);
      margin: 0 0 12px;
    }
    .swip-option-title {
      font-size: 22px;
      font-weight: 300;
      color: #fff;
      letter-spacing: -0.02em;
      margin: 0 0 16px;
    }
    .swip-option-body {
      font-size: 13px;
      color: rgba(168,168,168,0.6);
      line-height: 1.7;
      margin: 0 0 32px;
      flex: 1;
    }
    .swip-btn-bot, .swip-btn-wa {
      display: inline-block;
      padding: 14px 28px;
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      text-decoration: none;
      border: 1px solid rgba(255,255,255,0.25);
      color: #fff;
      background: none;
      cursor: pointer;
      font-family: inherit;
      transition: all 0.2s;
      text-align: center;
    }
    .swip-btn-bot:hover, .swip-btn-wa:hover {
      background: rgba(255,255,255,0.06);
      border-color: rgba(255,255,255,0.5);
    }
    @media (max-width: 600px) {
      #swip-modal { padding: 40px 24px; }
      .swip-modal-options { grid-template-columns: 1fr; }
      .swip-modal-divider { display: none; }
    }
  </style>

  <script is:inline>
    window.openSwipModal = function() {
      var overlay = document.getElementById('swip-modal-overlay');
      overlay.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    };
    function closeSwipModal() {
      document.getElementById('swip-modal-overlay').style.display = 'none';
      document.body.style.overflow = '';
    }
    document.getElementById('swip-modal-close').addEventListener('click', closeSwipModal);
    document.getElementById('swip-modal-overlay').addEventListener('click', function(e) {
      if (e.target === this) closeSwipModal();
    });
    document.getElementById('swip-open-bot').addEventListener('click', function() {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: 'chatbot_started' });
      closeSwipModal();
      setTimeout(function() {
        if (window.ChatFlowWidget) window.ChatFlowWidget.open();
      }, 300);
    });
    document.getElementById('swip-open-wa').addEventListener('click', function() {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: 'whatsapp_click', from_modal: true });
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeSwipModal();
    });
  </script>
  <script
    defer
    src="https://chatapp.chatflow.mx/widget.js"
    data-agent-id="a6b8378e-05dc-4bcc-a2a7-261c7ae146ec"
    data-position="bottom-right"
    data-primary-color="#2d2d2d"
    data-greeting="¡Hola! Soy SwipBot. ¿En qué puedo ayudarte?"
  ></script>
</body>
</html>
