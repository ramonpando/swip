---
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description: string;
  date: string;
  updatedDate?: string;
  category: string;
  slug: string;
  image?: string;
  relatedPosts?: Array<{
    title: string;
    description: string;
    category: string;
    slug: string;
  }>;
}

const {
  title,
  description,
  date,
  updatedDate,
  category,
  slug,
  image,
  relatedPosts = [],
} = Astro.props;

const canonical = `https://swip.mx/blog/${slug}/`;
const blogIndex = 'https://swip.mx/blog/';
const dateFormatted = new Date(date).toLocaleDateString('es-MX', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const updatedDateFormatted = updatedDate && new Date(updatedDate).toLocaleDateString('es-MX', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "@id": `${canonical}#article`,
  "headline": title,
  "description": description,
  "datePublished": date,
  ...(updatedDate ? { "dateModified": updatedDate } : {}),
  "inLanguage": "es-MX",
  "articleSection": category,
  "mainEntityOfPage": canonical,
  "author": {
    "@type": "Person",
    "@id": "https://swip.mx/#ramon-pando",
    "name": "Ramon Pando",
    "jobTitle": "Fundador y Director General",
    "url": "https://swip.mx",
    "worksFor": {
      "@id": "https://swip.mx/#organization",
    },
  },
  "publisher": {
    "@type": "Organization",
    "name": "SWIP",
    "url": "https://swip.mx",
    "logo": {
      "@type": "ImageObject",
      "url": "https://swip.mx/assets/logos/logo-light.svg",
    },
  },
  ...(image ? { image } : {}),
};

const WHATSAPP = 'https://wa.me/5215554055089?text=Hola%2C%20quiero%20cotizar%20un%20pr%C3%A9stamo%20con%20garant%C3%ADa%20de%20mi%20veh%C3%ADculo';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Inicio",
      "item": "https://swip.mx/",
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Blog",
      "item": blogIndex,
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": title,
      "item": canonical,
    },
  ],
};
---

<Base
  title={`${title} | SWIP`}
  description={description}
  canonical={canonical}
  ogImage={image}
  ogType="article"
  publishedTime={date}
  modifiedTime={updatedDate}
  schema={[articleSchema, breadcrumbSchema]}
>
  <Nav />
  <main>
    <section class="article-hero">
      <div class="article-inner">
        <a href="/blog/" class="back-link">← Volver al blog</a>
        <p class="article-category">{category}</p>
        <h1 class="article-title">{title}</h1>
        <p class="article-meta">
          <span>Publicado <time datetime={date}>{dateFormatted}</time></span>
          {updatedDate && updatedDateFormatted && (
            <span> · Actualizado <time datetime={updatedDate}>{updatedDateFormatted}</time></span>
          )}
        </p>
        <p class="article-description">{description}</p>
      </div>
    </section>

    <article class="article-body">
      <div class="article-inner prose">
        <slot />
      </div>
    </article>

    {relatedPosts.length > 0 && (
      <section class="article-related" aria-labelledby="related-title">
        <div class="related-inner">
          <p class="related-eyebrow">CONTINÚA EXPLORANDO</p>
          <h2 id="related-title" class="related-title">Artículos relacionados</h2>
          <div class="related-grid">
            {relatedPosts.map((post) => (
              <a href={`/blog/${post.slug}/`} class="related-card">
                <p class="related-category">{post.category}</p>
                <h3>{post.title}</h3>
                <p>{post.description}</p>
                <span>Leer artículo →</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="article-author">
      <div class="article-inner author-inner">
        <div class="author-card">
          <div class="author-text">
            <p class="author-name">Ramon Pando</p>
            <p class="author-role">Fundador y Director General, SWIP</p>
            <p class="author-bio">Fundó SWIP en 2023 con el objetivo de ofrecer liquidez real a propietarios de vehículos de alto valor en México. Más de 10 años en estructuración de activos y financiamiento alternativo. Opera personalmente cada valuación de activos complejos — blindados, exóticos y vehículos de producción limitada.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="article-cta">
      <div class="article-inner cta-inner">
        <p class="cta-eyebrow">SIGUIENTE PASO</p>
        <h2 class="cta-title">Convierte la información en una valuación real.</h2>
        <p class="cta-body">
          Si tu vehículo tiene valor y quieres saber cuánto puedes obtener,
          pasa a la evaluación con el equipo de SWIP.
        </p>
        <div class="cta-actions">
          <button onclick="openSwipModal()" class="btn-primary">Cotiza tu préstamo</button>
          <a href="/prestamo-con-garantia-de-auto/" class="btn-ghost">Ver el servicio completo →</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Base>

<style is:global>
  main {
    padding-top: 61px;
  }

  .article-hero,
  .article-body,
  .article-related,
  .article-cta {
    border-bottom: 1px solid var(--line);
  }

  .article-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 88px 64px;
  }

  .article-hero .article-inner {
    padding-bottom: 72px;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 28px;
    font-size: 11px;
    letter-spacing: 0.22em;
    color: rgba(168, 168, 168, 0.54);
    text-decoration: none;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--white);
  }

  .article-category {
    font-size: 9px;
    letter-spacing: 0.42em;
    color: rgba(168, 168, 168, 0.42);
    text-transform: uppercase;
    margin-bottom: 24px;
  }

  .article-title {
    font-size: clamp(40px, 5vw, 72px);
    font-weight: 400;
    color: var(--white);
    letter-spacing: -0.03em;
    line-height: 0.98;
    margin-bottom: 18px;
  }

  .article-meta {
    font-size: 11px;
    letter-spacing: 0.18em;
    color: rgba(168, 168, 168, 0.38);
    text-transform: uppercase;
    margin-bottom: 28px;
  }

  .article-description {
    max-width: 680px;
    font-size: 16px;
    line-height: 1.9;
    color: rgba(168, 168, 168, 0.78);
  }

  .prose {
    font-size: 17px;
    line-height: 1.95;
    color: rgba(168, 168, 168, 0.78);
  }

  .prose > *:first-child {
    margin-top: 0;
  }

  .prose h2 {
    font-size: 34px;
    font-weight: 300;
    color: var(--white);
    letter-spacing: -0.02em;
    line-height: 1.08;
    margin: 56px 0 20px;
  }

  .prose h3 {
    font-size: 24px;
    font-weight: 400;
    color: var(--white);
    letter-spacing: -0.01em;
    margin: 40px 0 16px;
  }

  .prose p {
    margin-bottom: 22px;
  }

  .prose ul,
  .prose ol {
    margin: 0 0 24px 24px;
  }

  .prose li {
    margin-bottom: 10px;
  }

  .prose strong {
    color: var(--white);
    font-weight: 500;
  }

  .prose a {
    color: var(--white);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .prose blockquote {
    border-left: 2px solid rgba(255, 255, 255, 0.14);
    padding-left: 22px;
    margin: 36px 0;
    color: rgba(168, 168, 168, 0.66);
  }

  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 40px 0;
    font-size: 15px;
  }

  .prose th,
  .prose td {
    text-align: left;
    padding: 12px 14px;
    border-bottom: 1px solid var(--line);
  }

  .prose th {
    color: var(--white);
    font-weight: 400;
  }

  .article-author {
    border-bottom: 1px solid var(--line);
  }

  .related-inner {
    max-width: 1180px;
    margin: 0 auto;
    padding: 72px 64px;
  }

  .related-eyebrow {
    font-size: 9px;
    letter-spacing: 0.42em;
    color: rgba(168, 168, 168, 0.4);
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .related-title {
    font-size: clamp(30px, 3.5vw, 46px);
    font-weight: 300;
    color: var(--white);
    letter-spacing: -0.02em;
    margin-bottom: 32px;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }

  .related-card {
    display: flex;
    flex-direction: column;
    min-width: 0;
    padding: 28px;
    color: inherit;
    background: var(--black);
    text-decoration: none;
    transition: background 0.2s;
  }

  .related-card:hover {
    background: rgba(255, 255, 255, 0.025);
  }

  .related-category {
    font-size: 9px;
    letter-spacing: 0.3em;
    color: rgba(168, 168, 168, 0.4);
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .related-card h3 {
    font-size: 20px;
    font-weight: 400;
    line-height: 1.25;
    color: var(--white);
    margin-bottom: 14px;
  }

  .related-card > p:last-of-type {
    flex: 1;
    font-size: 13px;
    line-height: 1.7;
    color: rgba(168, 168, 168, 0.64);
    margin-bottom: 24px;
  }

  .related-card span {
    font-size: 10px;
    letter-spacing: 0.18em;
    color: rgba(168, 168, 168, 0.56);
    text-transform: uppercase;
  }

  .author-inner {
    padding-top: 56px;
    padding-bottom: 56px;
  }

  .author-card {
    display: flex;
    align-items: flex-start;
    gap: 24px;
  }

  .author-name {
    font-size: 15px;
    font-weight: 500;
    color: var(--white);
    margin-bottom: 4px;
  }

  .author-role {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(168, 168, 168, 0.45);
    margin-bottom: 14px;
  }

  .author-bio {
    font-size: 14px;
    line-height: 1.85;
    color: rgba(168, 168, 168, 0.62);
    max-width: 620px;
    margin-bottom: 0;
  }

  .cta-inner {
    text-align: center;
  }

  .cta-eyebrow {
    font-size: 9px;
    letter-spacing: 0.42em;
    color: rgba(168, 168, 168, 0.4);
    text-transform: uppercase;
    margin-bottom: 20px;
  }

  .cta-title {
    font-size: clamp(30px, 3.8vw, 52px);
    font-weight: 300;
    color: var(--white);
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin-bottom: 18px;
  }

  .cta-body {
    max-width: 560px;
    margin: 0 auto 34px;
    font-size: 15px;
    line-height: 1.85;
    color: rgba(168, 168, 168, 0.72);
  }

  .cta-actions {
    display: flex;
    justify-content: center;
    gap: 18px;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 16px 40px;
    border: 1px solid rgba(255,255,255,0.35);
    color: var(--white);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    font-family: inherit;
    background: none;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-primary:hover {
    background: rgba(255,255,255,0.06);
    border-color: rgba(255,255,255,0.6);
  }

  .btn-ghost {
    font-size: 11px;
    letter-spacing: 0.22em;
    color: rgba(168,168,168,0.6);
    text-decoration: none;
    text-transform: uppercase;
    transition: color 0.2s;
    display: inline-flex;
    align-items: center;
  }

  .btn-ghost:hover {
    color: var(--white);
  }

  @media (max-width: 768px) {
    .article-inner {
      padding: 64px 24px;
    }

    .related-inner {
      padding: 56px 24px;
    }

    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
