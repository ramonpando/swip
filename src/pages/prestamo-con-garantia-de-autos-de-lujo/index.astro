---
import Page from '../../layouts/Page.astro';
import FAQ from '../../components/FAQ.astro';
import CTASection from '../../components/CTASection.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';

const WHATSAPP = 'https://wa.me/5215554055089?text=Hola%2C%20quiero%20cotizar%20un%20pr%C3%A9stamo%20con%20garant%C3%ADa%20de%20mi%20auto%20de%20lujo';

const faqs = [
  { q: '¿Qué marcas de autos de lujo aceptan?', a: 'Aceptamos BMW, Mercedes-Benz, Porsche, Audi, Land Rover, Range Rover, Lexus, Cadillac, Volvo, Jaguar, Maserati, Genesis, Infiniti, Acura, Lincoln y equivalentes de segmento premium. Si tu marca no está en la lista, contáctanos — evaluamos cada caso.' },
  { q: '¿Cómo valúan un auto de lujo?', a: 'Usamos referencias de mercado especializadas para vehículos premium, considerando versión, paquete de equipamiento, historial de servicio y condición real. No aplicamos tablas genéricas que subestiman el vehículo — sabemos que un BMW M5 vale diferente a un 520i del mismo año.' },
  { q: '¿Puedo obtener más dinero por un auto de lujo que por uno regular?', a: 'Sí. El monto del préstamo es proporcional al valor del vehículo. Para autos de lujo trabajamos con montos desde $200,000 hasta $5,000,000 MXN dependiendo del modelo y condición. La modalidad con resguardo no tiene límite de monto.' },
  { q: '¿El auto queda en buenas condiciones durante el resguardo?', a: 'Sí. Nuestras instalaciones están especialmente acondicionadas para vehículos de valor. Cobertura de seguro activa durante todo el plazo, acceso controlado y condiciones de almacenamiento que preservan el estado del vehículo.' },
  { q: '¿Qué pasa si mi auto tiene un crédito vigente?', a: 'Depende del saldo y el valor del vehículo. Contáctanos con los detalles — en algunos casos es posible estructurar una operación que liquide el crédito existente y te provea liquidez adicional.' },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "FinancialService",
    "name": "Préstamo con Garantía de Autos de Lujo — SWIP",
    "description": "Préstamo con garantía de autos de lujo en México. Especialistas en BMW, Mercedes-Benz, Porsche, Audi, Land Rover y vehículos premium. Valuación precisa, montos hasta $5M MXN.",
    "url": "https://swip.mx/prestamo-con-garantia-de-autos-de-lujo/",
    "provider": { "@id": "https://swip.mx/#organization" },
    "areaServed": "MX",
    "serviceType": "Préstamo con garantía de autos de lujo",
    "mainEntityOfPage": "https://swip.mx/prestamo-con-garantia-de-autos-de-lujo/"
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Inicio",
        "item": "https://swip.mx/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Vehículos que aceptamos",
        "item": "https://swip.mx/vehiculos-que-aceptamos/"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "Autos de lujo",
        "item": "https://swip.mx/prestamo-con-garantia-de-autos-de-lujo/"
      }
    ]
  }
];
---
<Page
  title="Préstamo con Garantía de Autos de Lujo en México | SWIP"
  description="Obtén liquidez con tu auto de lujo como garantía. BMW, Mercedes-Benz, Porsche, Audi, Land Rover y más. Valuación especializada, montos hasta $5M MXN. CDMX y Querétaro."
  schema={schema}
>

  <section class="page-hero">
    <div class="hero-inner">
      <p class="eyebrow">AUTOS DE LUJO · PRÉSTAMO CON GARANTÍA · MÉXICO</p>
      <h1 class="hero-title">Tu auto de lujo<br />vale más de lo que<br />te han ofrecido.</h1>
      <p class="hero-body">
        La mayoría de las empresas no saben cómo valuar correctamente un vehículo
        premium. Swip sí. Valuación especializada, monto justo, proceso discreto.
        Si todavía no sabes si tu unidad entra en el perfil, revisa <a href="/vehiculos-que-aceptamos/">vehículos que aceptamos</a>.
      </p>
      <div class="hero-actions">
        <a href={WHATSAPP} target="_blank" rel="noopener" class="btn-primary">Cotiza tu préstamo</a>
        <a href="/vehiculos-que-aceptamos/" class="btn-ghost">Ver vehículos →</a>
      </div>
    </div>
  </section>

  <!-- POR QUÉ ESPECIALIZACIÓN -->
  <section class="content-section">
    <div class="section-inner two-col">
      <div>
        <p class="section-eyebrow">POR QUÉ IMPORTA</p>
        <h2 class="section-title">La valuación<br />lo cambia todo.</h2>
      </div>
      <div class="section-text">
        <p>Un BMW Serie 7, un Porsche Panamera o un Mercedes-Benz GLE no se valúan igual que un auto popular. Tienen versiones, paquetes de equipamiento, historial de servicio y condiciones que impactan significativamente su valor real de mercado.</p>
        <p>La mayoría de las empresas de empeño aplican tablas genéricas que subestiman el vehículo hasta en un 30–40%. Swip usa referencias especializadas para el segmento premium, lo que se traduce directamente en un monto de préstamo más alto para ti.</p>
        <p>Para vehículos de lujo, elegir al valuador correcto puede significar la diferencia entre $300,000 y $600,000 MXN de préstamo sobre el mismo auto.</p>
      </div>
    </div>
  </section>

  <!-- MARCAS -->
  <section class="content-section">
    <div class="section-inner">
      <p class="section-eyebrow">MARCAS QUE VALUAMOS</p>
      <h2 class="section-title">Los que otros<br />no saben valuar.</h2>
      <div class="brands-section">
        <div class="brand-tier">
          <p class="tier-label">ALEMANAS</p>
          <div class="brand-list">
            <div class="brand-item">
              <p class="brand-name">BMW</p>
              <p class="brand-detail">Serie 3, 5, 7, 8 · X5, X6, X7 · M Series</p>
            </div>
            <div class="brand-item">
              <p class="brand-name">Mercedes-Benz</p>
              <p class="brand-detail">Clase C, E, S · GLE, GLS, G-Class · AMG</p>
            </div>
            <div class="brand-item">
              <p class="brand-name">Porsche</p>
              <p class="brand-detail">Cayenne · Panamera · Macan · 911</p>
            </div>
            <div class="brand-item">
              <p class="brand-name">Audi</p>
              <p class="brand-detail">A6, A7, A8 · Q7, Q8 · RS Series</p>
            </div>
          </div>
        </div>
        <div class="brand-tier">
          <p class="tier-label">BRITÁNICAS Y OTRAS</p>
          <div class="brand-list">
            <div class="brand-item">
              <p class="brand-name">Land Rover / Range Rover</p>
              <p class="brand-detail">Range Rover · Discovery · Defender</p>
            </div>
            <div class="brand-item">
              <p class="brand-name">Lexus</p>
              <p class="brand-detail">LS · LX · GX · RX · LC</p>
            </div>
            <div class="brand-item">
              <p class="brand-name">Otras marcas premium</p>
              <p class="brand-detail">Cadillac · Volvo · Jaguar · Maserati · Genesis · Infiniti</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MONTOS -->
  <section class="content-section">
    <div class="section-inner">
      <p class="section-eyebrow">MONTOS PARA AUTOS DE LUJO</p>
      <h2 class="section-title">El monto que<br />el vehículo merece.</h2>
      <div class="montos-grid">
        <div class="monto-card">
          <p class="monto-tag">SIN RESGUARDO</p>
          <p class="monto-val">Hasta $400,000 MXN</p>
          <p class="monto-desc">Conservas el uso del vehículo con monitoreo activo. Disponible para vehículos de hasta cierto valor según condiciones.</p>
        </div>
        <div class="monto-card">
          <p class="monto-tag">CON RESGUARDO</p>
          <p class="monto-val">Sin límite de monto</p>
          <p class="monto-desc">Para autos de lujo de alto valor, la modalidad con resguardo permite montos que reflejan el valor real del vehículo — sin techo artificial.</p>
        </div>
        <div class="monto-card monto-card--note">
          <p class="monto-desc">Para vehículos como un Porsche 911, Mercedes Clase S o BMW X7 de año reciente, los montos pueden superar $1,000,000 MXN. Cada caso se evalúa individualmente con valuación en persona.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PROCESO -->
  <section class="content-section">
    <div class="section-inner">
      <p class="section-eyebrow">PROCESO</p>
      <h2 class="section-title">Discreto desde<br />el primer contacto.</h2>
      <div class="steps-grid">
        <div class="step">
          <p class="step-num">01</p>
          <h3 class="step-title">Contacto confidencial</h3>
          <p class="step-desc">Por WhatsApp o cotizador. Nos compartes marca, modelo, año y kilometraje. Estimado en minutos.</p>
        </div>
        <div class="step">
          <p class="step-num">02</p>
          <h3 class="step-title">Valuación especializada</h3>
          <p class="step-desc">Valuador con experiencia en vehículos premium. Revisión en tu domicilio o en nuestras instalaciones.</p>
        </div>
        <div class="step">
          <p class="step-num">03</p>
          <h3 class="step-title">Oferta precisa</h3>
          <p class="step-desc">Monto, tasa y plazo basados en el valor real del vehículo. Sin sorpresas ni cambios de último momento.</p>
        </div>
        <div class="step">
          <p class="step-num">04</p>
          <h3 class="step-title">Depósito en 24 h</h3>
          <p class="step-desc">Transferencia directa a tu cuenta bancaria en menos de 24 horas de firmado el contrato.</p>
        </div>
      </div>
    </div>
  </section>

  <RelatedLinks
    title="Conecta la valuación premium con la operación correcta."
    items={[
      {
        href: '/vehiculos-que-aceptamos/',
        label: 'Vehículos aceptados',
        description: 'Contrasta tu auto de lujo con el resto de los segmentos que SWIP sabe valuar.',
      },
      {
        href: '/prestamo-con-garantia-de-auto-con-resguardo/',
        label: 'Con resguardo',
        description: 'Para autos de lujo de alto valor, esta modalidad suele dar mejores montos y condiciones.',
      },
      {
        href: '/prestamo-con-garantia-de-auto/',
        label: 'Garantía vehicular',
        description: 'Vuelve al servicio base para ver modalidades, proceso y propuesta completa.',
      },
    ]}
  />

  <FAQ items={faqs} eyebrow="PREGUNTAS SOBRE AUTOS DE LUJO" />
  <CTASection
    eyebrow="VALUACIÓN ESPECIALIZADA"
    title="¿Cuánto puedes obtener por tu auto de lujo?"
    body="Cuéntanos la marca, modelo y año. Te damos un estimado real basado en el valor premium de tu vehículo."
  />

</Page>

<style>
  .page-hero { border-bottom: 1px solid var(--line); }
  .hero-inner { max-width: 1280px; margin: 0 auto; padding: 96px 64px 80px; }
  .eyebrow { font-size: 9px; letter-spacing: 0.42em; color: rgba(168,168,168,0.45); text-transform: uppercase; margin-bottom: 28px; }
  .hero-title { font-size: clamp(40px, 5vw, 72px); font-weight: 400; color: var(--white); letter-spacing: -0.02em; line-height: 1.0; margin-bottom: 24px; }
  .hero-body { max-width: 540px; font-size: 15px; color: rgba(168,168,168,0.78); line-height: 1.85; margin-bottom: 32px; }
  .hero-actions { display: flex; align-items: center; gap: 20px; flex-wrap: wrap; }
  .btn-primary { display: inline-flex; align-items: center; justify-content: center; min-height: 52px; padding: 16px 40px; border: 1px solid rgba(255,255,255,0.35); color: var(--white); font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; text-decoration: none; font-family: inherit; transition: all 0.2s; }
  .btn-primary:hover { background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.6); }
  .btn-ghost { font-size: 11px; letter-spacing: 0.22em; color: rgba(168,168,168,0.6); text-decoration: none; text-transform: uppercase; transition: color 0.2s; }
  .btn-ghost:hover { color: var(--white); }

  .content-section { border-bottom: 1px solid var(--line); }
  .section-inner { max-width: 1280px; margin: 0 auto; padding: 96px 64px; }
  .section-inner.two-col { display: grid; grid-template-columns: 1fr 1.4fr; gap: 80px; align-items: start; }
  .section-eyebrow { font-size: 9px; letter-spacing: 0.42em; color: rgba(168,168,168,0.38); text-transform: uppercase; margin-bottom: 20px; }
  .section-title { font-size: clamp(28px, 3.2vw, 44px); font-weight: 300; color: var(--white); letter-spacing: -0.02em; line-height: 1.05; }
  .section-text p { font-size: 15px; color: rgba(168,168,168,0.72); line-height: 1.85; margin-bottom: 16px; }

  /* BRANDS */
  .brands-section { margin-top: 56px; display: flex; flex-direction: column; gap: 1px; background: var(--line); border: 1px solid var(--line); }
  .brand-tier { background: var(--black); padding: 40px; }
  .tier-label { font-size: 9px; letter-spacing: 0.36em; color: rgba(168,168,168,0.3); text-transform: uppercase; margin-bottom: 24px; }
  .brand-list { display: grid; grid-template-columns: repeat(4,1fr); gap: 1px; background: var(--line); }
  .brand-item { background: var(--black); padding: 24px 20px; }
  .brand-name { font-size: 14px; font-weight: 500; color: var(--white); margin-bottom: 6px; }
  .brand-detail { font-size: 11px; color: rgba(168,168,168,0.48); line-height: 1.6; }

  /* MONTOS */
  .montos-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1px; background: var(--line); border: 1px solid var(--line); margin-top: 56px; }
  .monto-card { background: var(--black); padding: 40px 36px; }
  .monto-card--note { background: rgba(255,255,255,0.01); }
  .monto-tag { font-size: 9px; letter-spacing: 0.36em; color: rgba(168,168,168,0.3); text-transform: uppercase; margin-bottom: 12px; }
  .monto-val { font-size: 22px; font-weight: 300; color: var(--white); letter-spacing: -0.02em; margin-bottom: 14px; }
  .monto-desc { font-size: 13px; color: rgba(168,168,168,0.62); line-height: 1.8; }

  /* STEPS */
  .steps-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 1px; background: var(--line); border: 1px solid var(--line); margin-top: 56px; }
  .step { background: var(--black); padding: 36px 28px; }
  .step-num { font-size: 11px; letter-spacing: 0.3em; color: rgba(168,168,168,0.22); margin-bottom: 16px; }
  .step-title { font-size: 15px; font-weight: 400; color: var(--white); margin-bottom: 10px; }
  .step-desc { font-size: 13px; color: rgba(168,168,168,0.58); line-height: 1.7; }

  @media (max-width: 1024px) {
    .section-inner.two-col { grid-template-columns: 1fr; gap: 40px; }
    .brand-list { grid-template-columns: repeat(2,1fr); }
    .steps-grid { grid-template-columns: repeat(2,1fr); }
    .montos-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 768px) {
    .hero-inner, .section-inner { padding: 64px 24px; }
    .hero-actions { flex-direction: column; align-items: stretch; gap: 14px; }
    .btn-primary { width: 100%; padding: 16px 24px; }
    .btn-ghost { display: inline-flex; align-items: center; min-height: 44px; }
    .brand-list, .montos-grid, .steps-grid { grid-template-columns: 1fr; }
    .brand-tier { padding: 28px 24px; }
    .monto-card, .step { padding: 32px 24px; }
  }
</style>
