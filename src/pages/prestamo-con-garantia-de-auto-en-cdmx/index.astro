---
import Page from '../../layouts/Page.astro';
import FAQ from '../../components/FAQ.astro';
import CTASection from '../../components/CTASection.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';

const WHATSAPP = 'https://wa.me/5215554055089?text=Hola%2C%20quiero%20cotizar%20un%20pr%C3%A9stamo%20con%20garant%C3%ADa%20de%20auto%20en%20CDMX';

const faqs = [
  { q: '¿SWIP atiende solo algunas zonas de CDMX?', a: 'Atendemos la zona metropolitana con foco en corredores donde se concentra el parque vehicular de mayor valor: Interlomas, Polanco, Lomas, Santa Fe, Pedregal, Tecamachalco y Bosques de las Lomas. Si tu vehículo está en otra zona, podemos revisar el caso.' },
  { q: '¿Puedo pedir la valuación en mi domicilio u oficina en CDMX?', a: 'Sí. La valuación puede realizarse en tu domicilio, oficina o en instalaciones SWIP, según la logística del caso y el tipo de vehículo.' },
  { q: '¿Qué tipo de autos aceptan en CDMX?', a: 'Trabajamos con autos de lujo, SUVs premium, vehículos blindados, autos exóticos y otras unidades de alto valor con mercado comprobable. También revisamos casos especiales cuando el activo justifica una operación seria.' },
  { q: '¿En cuánto tiempo puedo recibir respuesta en Ciudad de México?', a: 'El estimado inicial suele salir en minutos y, si el caso avanza con documentación lista, la operación completa puede resolverse el mismo día hábil. El depósito se realiza en menos de 24 horas después de firmar.' },
  { q: '¿Conviene más con resguardo o sin dejarlo?', a: 'Depende de tu objetivo. Si buscas el mayor monto posible, normalmente conviene la modalidad con resguardo. Si necesitas seguir usando el vehículo, evaluamos la modalidad sin dejarlo dentro de los límites operativos del caso.' },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "FinancialService",
    "@id": "https://swip.mx/prestamo-con-garantia-de-auto-en-cdmx/#service",
    "name": "Préstamo con Garantía de Auto en CDMX — SWIP",
    "description": "Préstamo con garantía de auto en Ciudad de México. Valuación seria para autos de lujo, blindados y vehículos de alto valor con atención en domicilio u oficina.",
    "url": "https://swip.mx/prestamo-con-garantia-de-auto-en-cdmx/",
    "provider": { "@id": "https://swip.mx/#organization" },
    "areaServed": {
      "@type": "City",
      "name": "Ciudad de México",
      "sameAs": "https://www.wikidata.org/wiki/Q1489"
    },
    "serviceType": "Préstamo con garantía vehicular en Ciudad de México",
    "currenciesAccepted": "MXN",
    "mainEntityOfPage": "https://swip.mx/prestamo-con-garantia-de-auto-en-cdmx/"
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Inicio",
        "item": "https://swip.mx/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Préstamo con garantía de auto",
        "item": "https://swip.mx/prestamo-con-garantia-de-auto/"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "CDMX",
        "item": "https://swip.mx/prestamo-con-garantia-de-auto-en-cdmx/"
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  }
];
---
<Page
  title="Préstamo con Garantía de Auto en CDMX | SWIP"
  description="Obtén un préstamo con garantía de auto en CDMX con valuación seria, atención discreta y respuesta rápida. SWIP atiende autos de lujo, blindados y vehículos de alto valor."
  schema={schema}
>
  <link slot="head" rel="preload" as="image" href="/assets/images/hero.jpg" fetchpriority="high" />

  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-overlay"></div>
    <div class="hero-statement">
      <div class="hero-grid">
        <div class="hero-copy">
          <p class="hero-eyebrow">SWIP · PRÉSTAMO CON GARANTÍA DE AUTO · CDMX</p>
          <h1 class="hero-title">
            Liquidez en 24 horas<br />
            <em>con tu auto en Ciudad de México.</em>
          </h1>
          <p class="hero-body">
            Sin buró de crédito, sin vender tu vehículo. SWIP valúa tu auto en
            domicilio u oficina y deposita en menos de 24 horas.
          </p>
          <p class="hero-spec">Autos de lujo, <a href="/prestamo-con-garantia-de-autos-blindados/">blindados</a> y vehículos de alto valor en CDMX y zona metropolitana.</p>
          <div class="hero-actions">
            <button onclick="openSwipModal()" class="btn-primary">Cotiza gratis — sin compromiso</button>
            <a href="/contacto/" class="btn-ghost">Hablar con un asesor →</a>
          </div>
          <p class="hero-trust">Sin buró de crédito &nbsp;·&nbsp; Sin vender tu auto &nbsp;·&nbsp; Depósito en 24 h</p>
        </div>
      </div>
    </div>
    <div class="stats-bar">
      <div class="stat-item">
        <div class="stat-number">24 h</div>
        <div class="stat-label">Depósito máximo</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">$0</div>
        <div class="stat-label">Costo de valuación</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">4.5%</div>
        <div class="stat-label">Tasa mensual desde</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">$90k–$5M</div>
        <div class="stat-label">Rango de préstamo en MXN</div>
      </div>
    </div>
  </section>

  <section class="brands-section">
    <div class="brands-inner">
      <p class="brands-eyebrow">Valuamos estas marcas y más</p>
      <div class="brands-strip">
        <span>BMW</span>
        <span>Mercedes-Benz</span>
        <span>Porsche</span>
        <span>Audi</span>
        <span>Land Rover</span>
        <span>Lexus</span>
        <span>Cadillac</span>
        <span>Blindados</span>
        <span>Exóticos</span>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="section-inner two-col">
      <div>
        <p class="section-eyebrow">POR QUÉ CDMX</p>
        <h2 class="section-title">Una plaza donde<br />la valuación pesa más.</h2>
      </div>
      <div class="section-text">
        <p>Ciudad de México concentra una parte importante del parque vehicular premium del país. Cuando el auto vale más, una valuación superficial destruye monto. Por eso SWIP trabaja esta plaza con criterio de activo, no con tablas rápidas.</p>
        <p>Operamos con atención en domicilio u oficina en corredores como Interlomas, Polanco, Lomas, Santa Fe, Pedregal, Tecamachalco y Bosques de las Lomas. Eso reduce fricción, ahorra tiempo y mantiene el proceso más reservado.</p>
        <p>Si tu caso encaja mejor en otra ruta, también puedes revisar la página general de <a href="/prestamo-con-garantia-de-auto/">préstamo con garantía de auto</a> o la especialidad de <a href="/prestamo-con-garantia-de-autos-de-lujo/">autos de lujo</a>.</p>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="section-inner">
      <p class="section-eyebrow">DÓNDE HACE MÁS SENTIDO</p>
      <h2 class="section-title">Casos típicos en<br />Ciudad de México.</h2>
      <div class="use-grid">
        <div class="use-card">
          <p class="use-tag">LIQUIDEZ RÁPIDA</p>
          <h3 class="use-title">Resolver necesidad de capital sin vender el auto</h3>
          <p class="use-desc">Cuando el vehículo es parte importante de tu patrimonio, usarlo como respaldo puede ser más eficiente que liquidarlo con prisa o aceptar una valuación baja.</p>
        </div>
        <div class="use-card">
          <p class="use-tag">SEGMENTO PREMIUM</p>
          <h3 class="use-title">Vehículos que requieren criterio de valuación real</h3>
          <p class="use-desc">BMW, Mercedes-Benz, Porsche, Audi, Range Rover, SUVs premium, blindados y otros activos donde versión, equipamiento y condición cambian fuerte el monto.</p>
        </div>
        <div class="use-card">
          <p class="use-tag">OPERACIÓN DISCRETA</p>
          <h3 class="use-title">Atención directa sin procesos impersonales</h3>
          <p class="use-desc">En CDMX la velocidad importa, pero también la discreción. El contacto inicia por WhatsApp con conversación útil, no con un flujo genérico de formularios.</p>
        </div>
      </div>
      <div class="mid-cta">
        <button onclick="openSwipModal()" class="btn-primary">¿Tu vehículo aplica? Cotiza gratis →</button>
      </div>
    </div>
  </section>

  <section id="como-funciona" class="content-section">
    <div class="section-inner">
      <p class="section-eyebrow">PROCESO EN CDMX</p>
      <h2 class="section-title">Cuatro pasos.<br />Sin vueltas innecesarias.</h2>
      <div class="steps-grid">
        <div class="step">
          <div class="step-num">01</div>
          <h3 class="step-title">Contacto inicial</h3>
          <p class="step-desc">Compartes marca, modelo, año y kilometraje. Recibes una lectura inicial para saber si el caso hace sentido.</p>
        </div>
        <div class="step">
          <div class="step-num">02</div>
          <h3 class="step-title">Valuación en persona</h3>
          <p class="step-desc">Revisión del vehículo en domicilio, oficina o instalaciones SWIP según la logística del caso en la zona metropolitana.</p>
        </div>
        <div class="step">
          <div class="step-num">03</div>
          <h3 class="step-title">Oferta documentada</h3>
          <p class="step-desc">Monto, plazo y condiciones definidos después de ver el activo real, no antes.</p>
        </div>
        <div class="step">
          <div class="step-num">04</div>
          <h3 class="step-title">Depósito</h3>
          <p class="step-desc">Si todo está en orden, la operación puede cerrarse el mismo día hábil y el depósito sale en menos de 24 horas.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="section-inner">
      <p class="section-eyebrow">MODALIDADES</p>
      <h2 class="section-title">Dos formas de<br />obtener liquidez.</h2>
      <div class="modal-grid">
        <div class="modal-card">
          <p class="modal-tag">CON RESGUARDO</p>
          <h3 class="modal-title">Dejas el vehículo,<br />obtienes el máximo.</h3>
          <p class="modal-desc">Tu auto queda en instalaciones seguras y monitoreadas durante el plazo. Esta modalidad permite los montos más altos, mejor tasa y menor fricción en la valuación — es la opción cuando el objetivo es maximizar el préstamo.</p>
          <ul class="modal-features">
            <li>Monto máximo sobre el valor del activo</li>
            <li>Tasa más baja al reducir el riesgo operativo</li>
            <li>Instalaciones seguras, monitoreadas 24/7</li>
          </ul>
          <a href="/prestamo-con-garantia-de-auto-con-resguardo/" class="modal-link">Ver modalidad →</a>
        </div>
        <div class="modal-card">
          <p class="modal-tag">SIN DEJARLO</p>
          <h3 class="modal-title">Conservas el auto,<br />sigues moviéndote.</h3>
          <p class="modal-desc">Mantienes el uso de tu vehículo en CDMX bajo condiciones de monitoreo GPS durante el plazo. El monto es algo menor al de la modalidad con resguardo, pero conservas tu movilidad completa.</p>
          <ul class="modal-features">
            <li>Sigues usando tu auto todos los días</li>
            <li>Monitoreo GPS durante el plazo del préstamo</li>
            <li>Monto ajustado al riesgo operativo del caso</li>
          </ul>
          <a href="/prestamo-con-garantia-de-auto-sin-dejarlo/" class="modal-link">Ver modalidad →</a>
        </div>
      </div>
    </div>
  </section>

  <RelatedLinks
    eyebrow="RUTAS RELACIONADAS"
    title="Abre la página que mejor responde tu caso en CDMX."
    items={[
      {
        href: '/prestamo-con-garantia-de-autos-de-lujo/',
        label: 'Autos de lujo',
        description: 'Para BMW, Mercedes-Benz, Porsche, Audi, Land Rover y otras unidades premium.',
      },
      {
        href: '/prestamo-con-garantia-de-autos-blindados/',
        label: 'Autos blindados',
        description: 'Cuando el blindaje debe reflejarse en la valuación y no perderse en una tabla genérica.',
      },
      {
        href: '/blog/donde-valuan-autos-de-lujo-a-domicilio-en-cdmx/',
        label: 'Valuación a domicilio en CDMX',
        description: 'Cómo funciona la valuación en tu domicilio u oficina para autos de lujo en Ciudad de México.',
      },
      {
        href: '/contacto/',
        label: 'Contacto',
        description: 'Habla con un asesor si quieres validar cobertura, tiempos y modalidad para tu vehículo.',
      },
    ]}
  />

  <FAQ items={faqs} eyebrow="PREGUNTAS FRECUENTES · CDMX" />

  <section class="legal-disclosure">
    <div class="legal-inner">
      <p class="legal-text">
        CORPOSWIP LATAM S.A.P.I. de C.V. · RFC: CLA230824RS7 · Nombre comercial: SWIP ·
        Préstamos con garantía vehicular desde $90,000 hasta $5,000,000 MXN ·
        Tasa de interés mensual desde 4.5% sobre saldo insoluto · El monto y la tasa
        dependen del valor del vehículo y las condiciones de la operación ·
        Pje. Interlomas 6, Bosques de las Palmas, Huixquilucan, Estado de México, C.P. 52787 ·
        Tel. 55 5405 5089
      </p>
    </div>
  </section>

  <CTASection
    eyebrow="SIGUIENTE PASO · CDMX"
    title="Si el auto tiene valor,\nla valuación correcta importa."
    body="Comparte los datos básicos de tu vehículo y te diremos rápido si el caso encaja con SWIP en Ciudad de México."
    primaryLabel="Cotizar en CDMX"
  />
</Page>

<style>
  .content-section {
    border-bottom: 1px solid var(--line);
  }

  .hero {
    height: calc(100vh - 61px);
    min-height: 600px;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--line);
  }

  .hero-bg {
    position: absolute;
    inset: -10%;
    background: url('/assets/images/hero.jpg') center center / cover no-repeat;
    transform: scale(1.2);
    transform-origin: center center;
    z-index: 0;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(10,10,10,0.94) 0%, rgba(10,10,10,0.82) 35%, rgba(10,10,10,0.5) 65%, rgba(10,10,10,0.2) 100%),
      linear-gradient(180deg, rgba(10,10,10,0.1) 0%, rgba(10,10,10,0.05) 50%, rgba(10,10,10,0.65) 100%);
    z-index: 1;
  }

  .hero-statement {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 56px 64px 44px;
    width: 100%;
    max-width: 1280px;
    align-self: center;
    position: relative;
    z-index: 2;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 680px);
    align-items: center;
  }

  .hero-eyebrow {
    font-size: 9px;
    letter-spacing: 0.42em;
    color: rgba(168,168,168,0.58);
    text-transform: uppercase;
    margin-bottom: 28px;
  }

  .hero-title {
    font-size: clamp(52px, 6.2vw, 84px);
    font-weight: 400;
    color: var(--white);
    letter-spacing: -0.01em;
    line-height: 1.0;
    margin-bottom: 24px;
  }

  .hero-title em {
    display: block;
    margin-top: 8px;
    font-style: normal;
    font-size: 0.72em;
    color: rgba(168,168,168,0.6);
    letter-spacing: -0.01em;
  }

  .hero-body {
    max-width: 500px;
    font-size: 15px;
    color: rgba(198,198,198,0.88);
    line-height: 1.85;
    margin-bottom: 16px;
  }

  .hero-spec {
    font-size: 13px;
    font-weight: 500;
    color: var(--white);
    letter-spacing: 0.01em;
    margin-bottom: 36px;
  }

  .hero-spec a {
    color: var(--white);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .hero-trust {
    margin-top: 20px;
    font-size: 10px;
    letter-spacing: 0.16em;
    color: rgba(168,168,168,0.45);
    text-transform: uppercase;
  }

  .stats-bar {
    position: relative;
    z-index: 2;
    border-top: 1px solid rgba(255,255,255,0.1);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    background: rgba(10,10,10,0.72);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    flex-shrink: 0;
  }

  .stat-item {
    padding: 28px 40px;
    border-right: 1px solid var(--line);
  }

  .stat-number {
    font-size: 22px;
    font-weight: 300;
    color: var(--white);
    letter-spacing: -0.01em;
    margin-bottom: 4px;
  }

  .stat-label {
    font-size: 10px;
    letter-spacing: 0.26em;
    color: rgba(168,168,168,0.4);
    text-transform: uppercase;
  }

  .brands-section {
    border-bottom: 1px solid var(--line);
  }

  .brands-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 32px 64px;
    display: flex;
    align-items: center;
    gap: 40px;
    flex-wrap: wrap;
  }

  .brands-eyebrow {
    font-size: 9px;
    letter-spacing: 0.36em;
    color: rgba(168,168,168,0.3);
    text-transform: uppercase;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .brands-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 32px;
    align-items: center;
  }

  .brands-strip span {
    font-size: 12px;
    letter-spacing: 0.14em;
    color: rgba(168,168,168,0.5);
    text-transform: uppercase;
  }

  .mid-cta {
    margin-top: 48px;
    padding-top: 40px;
    border-top: 1px solid var(--line);
  }

  .modal-features {
    list-style: none;
    padding: 0;
    margin: 16px 0 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .modal-features li {
    font-size: 12px;
    color: rgba(168,168,168,0.5);
    letter-spacing: 0.04em;
    padding-left: 16px;
    position: relative;
  }

  .modal-features li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: rgba(168,168,168,0.25);
  }

  .legal-disclosure {
    border-top: 1px solid var(--line);
  }

  .legal-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 32px 64px;
  }

  .legal-text {
    font-size: 11px;
    color: rgba(168,168,168,0.35);
    line-height: 1.8;
  }

  .section-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 96px 64px;
  }

  .two-col {
    display: grid;
    grid-template-columns: 1fr 1.35fr;
    gap: 80px;
    align-items: start;
  }

  .eyebrow,
  .section-eyebrow {
    font-size: 9px;
    letter-spacing: 0.42em;
    color: rgba(168,168,168,0.4);
    text-transform: uppercase;
    margin-bottom: 20px;
  }

  .hero-title,
  .section-title {
    font-size: clamp(34px, 4.8vw, 72px);
    font-weight: 300;
    color: var(--white);
    letter-spacing: -0.02em;
    line-height: 1.02;
    margin-bottom: 24px;
  }

  .hero-body,
  .section-text p {
    font-size: 15px;
    color: rgba(168,168,168,0.76);
    line-height: 1.85;
  }

  .hero-body {
    max-width: 620px;
    margin-bottom: 32px;
  }

  .section-text p {
    margin-bottom: 20px;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 16px 40px;
    border: 1px solid rgba(255,255,255,0.35);
    color: var(--white);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    background: none;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-primary:hover {
    background: rgba(255,255,255,0.06);
    border-color: rgba(255,255,255,0.6);
  }

  .btn-ghost,
  .modal-link {
    font-size: 11px;
    letter-spacing: 0.22em;
    color: rgba(168,168,168,0.56);
    text-decoration: none;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .btn-ghost:hover,
  .modal-link:hover {
    color: var(--white);
  }

  .use-grid,
  .steps-grid,
  .modal-grid {
    display: grid;
    gap: 1px;
    background: var(--line);
    margin-top: 56px;
  }

  .use-grid {
    grid-template-columns: repeat(3, 1fr);
  }

  .steps-grid {
    grid-template-columns: repeat(4, 1fr);
  }

  .modal-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .use-card,
  .step,
  .modal-card {
    background: var(--black);
    padding: 40px 32px;
  }

  .use-tag,
  .modal-tag,
  .step-num {
    font-size: 9px;
    letter-spacing: 0.36em;
    color: rgba(168,168,168,0.3);
    text-transform: uppercase;
    margin-bottom: 18px;
  }

  .use-title,
  .modal-title,
  .step-title {
    font-size: 22px;
    font-weight: 300;
    color: var(--white);
    letter-spacing: -0.01em;
    margin-bottom: 12px;
  }

  .step-title {
    font-size: 17px;
  }

  .use-desc,
  .modal-desc,
  .step-desc {
    font-size: 13px;
    color: rgba(168,168,168,0.64);
    line-height: 1.75;
  }

  @media (max-width: 1024px) {
