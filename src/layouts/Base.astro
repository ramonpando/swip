---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  ogType?: string;
  publishedTime?: string;
  modifiedTime?: string;
  schema?: object | object[];
}

const {
  title,
  description,
  canonical,
  ogImage = 'https://swip.mx/assets/og-default.jpg',
  noindex = false,
  ogType = 'website',
  publishedTime,
  modifiedTime,
  schema,
} = Astro.props;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, 'https://swip.mx').href;
const baseSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://swip.mx/#organization",
      "name": "SWIP",
      "url": "https://swip.mx",
      "logo": "https://swip.mx/assets/logos/logo-light.svg",
      "description": "Liquidez inteligente con respaldo en tu auto. Préstamos con garantía vehicular para autos de lujo, blindados y vehículos de alto valor en México.",
      "email": "patricia_bernal@swip.mx",
      "telephone": "+52-1-55-5405-5089",
      "sameAs": [
        "https://wa.me/5215554055089"
      ]
    },
    {
      "@type": "FinancialService",
      "@id": "https://swip.mx/#financial-service",
      "name": "SWIP",
      "url": "https://swip.mx",
      "image": "https://swip.mx/assets/og-default.jpg",
      "description": "Préstamos con garantía vehicular para autos de lujo, blindados y vehículos de alto valor en México.",
      "currenciesAccepted": "MXN",
      "priceRange": "$$$$",
      "paymentAccepted": "Transferencia bancaria",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Pje. Interlomas 6",
        "addressLocality": "Naucalpan de Juárez",
        "addressRegion": "Estado de México",
        "postalCode": "52787",
        "addressCountry": "MX"
      },
      "areaServed": [
        {
          "@type": "City",
          "name": "Ciudad de México",
          "sameAs": "https://www.wikidata.org/wiki/Q1489"
        },
        {
          "@type": "City",
          "name": "Querétaro",
          "sameAs": "https://www.wikidata.org/wiki/Q16572"
        }
      ],
      "serviceArea": [
        { "@type": "City", "name": "Ciudad de México" },
        { "@type": "City", "name": "Querétaro" }
      ],
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": [
            "Monday",
            "Tuesday",
            "Wednesday",
            "Thursday",
            "Friday"
          ],
          "opens": "09:00",
          "closes": "19:00"
        }
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+52-1-55-5405-5089",
        "email": "patricia_bernal@swip.mx",
        "contactType": "sales",
        "areaServed": "MX",
        "availableLanguage": [
          "es",
          "es-MX"
        ]
      },
      "parentOrganization": {
        "@id": "https://swip.mx/#organization"
      }
    },
    {
      "@type": "WebSite",
      "@id": "https://swip.mx/#website",
      "url": "https://swip.mx",
      "name": "SWIP",
      "inLanguage": "es-MX",
      "publisher": {
        "@id": "https://swip.mx/#organization"
      }
    }
  ]
};
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content="SWIP" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content="es_MX" />
  {publishedTime && <meta property="article:published_time" content={publishedTime} />}
  {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Schema base: Organization -->
  <script type="application/ld+json" set:html={JSON.stringify(baseSchema)} />

  <!-- Schema adicional por página -->
  {schema && (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )}

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/assets/logos/favicon.svg" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@300;400;500&display=swap" rel="stylesheet" />

</head>
<body>
  <slot />
</body>
</html>
