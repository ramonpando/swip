---
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  schema?: object | object[];
}

const props = Astro.props;
---
<Base {...props}>
  <Nav />
  <main>
    <slot />
  </main>
  <Footer />
</Base>

<style is:global>
  main {
    padding-top: 61px;
  }
</style>
