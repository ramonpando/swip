---
---

<section class="preowned-section">
  <div class="po-inner">
    <div class="po-header">
      <div>
        <p class="po-eyebrow">PRE-OWNED · SWIP</p>
        <h2 class="po-title">Vehículos<br />certificados.</h2>
      </div>
      <a href="/pre-owned/" class="po-link-all">Ver inventario completo →</a>
    </div>
    <div class="po-grid" id="po-grid">
      <div class="po-skeleton"></div>
      <div class="po-skeleton"></div>
      <div class="po-skeleton"></div>
      <div class="po-skeleton"></div>
    </div>
  </div>
</section>

<script>
  const API = 'https://dashboard.bravix.com.mx/api/carflow/public/inventario?org=cmn0jyqvg0000rk01w30tuwky&limit=3';

  function fmt(n: number) {
    return '$' + n.toLocaleString('es-MX') + ' MXN';
  }

  function fmtKm(n: number) {
    return n.toLocaleString('es-MX') + ' km';
  }

  function cardHTML(v: any) {
    const title = `${v.marca} ${v.modelo} ${v.año}`;
    const badge = v.esBlindado
      ? `<span class="po-badge po-badge--blindado">Blindado${v.nivelBlindaje ? ' ' + v.nivelBlindaje.toUpperCase() : ''}</span>`
      : `<span class="po-badge">Certificado</span>`;
    const specs = [fmtKm(v.kilometraje), v.transmision, v.color].filter(Boolean).join(' · ');

    return `
      <a class="po-vehicle-card" href="${v.fichaUrl}" target="_blank" rel="noopener">
        <div class="po-img">
          ${v.fotoPrincipal ? `<img src="${v.fotoPrincipal}" alt="${title}" loading="lazy" />` : ''}
          ${badge}
        </div>
        <div class="po-info">
          <p class="po-name">${title}</p>
          <p class="po-meta">${specs}</p>
          <p class="po-price">${fmt(v.precioVenta)}</p>
          <span class="po-ficha">Ver ficha →</span>
        </div>
      </a>`;
  }

  const ctaCard = `
    <div class="po-cta-card">
      <p class="po-cta-eyebrow">Pre-Owned</p>
      <p class="po-cta-heading">Ver inventario<br />completo</p>
      <p class="po-cta-desc">Unidades certificadas con condición confirmada y documentación verificada.</p>
      <a href="/pre-owned/" class="po-cta-link">Ir a Pre-Owned →</a>
    </div>`;

  async function load() {
    const grid = document.getElementById('po-grid');
    if (!grid) return;
    try {
      const res = await fetch(API);
      const data = await res.json();
      const vehicles: any[] = data.vehiculos || [];
      grid.innerHTML = vehicles.map(cardHTML).join('') + ctaCard;
    } catch {
      grid.innerHTML = ctaCard;
    }
  }

  load();
</script>

<style is:global>
  .preowned-section {
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .po-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 80px 64px;
  }

  .po-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 40px;
  }

  .po-eyebrow {
    font-size: 9px;
    letter-spacing: 0.42em;
    color: rgba(168,168,168,0.38);
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .po-title {
    font-size: clamp(26px, 3vw, 42px);
    font-weight: 300;
    color: var(--white);
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin: 0;
  }

  .po-link-all {
    font-size: 11px;
    letter-spacing: 0.22em;
    color: rgba(168,168,168,0.45);
    text-decoration: none;
    text-transform: uppercase;
    transition: color 0.2s;
    white-space: nowrap;
  }
  .po-link-all:hover { color: var(--white); }

  /* GRID */
  .po-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }

  /* SKELETON */
  .po-skeleton {
    min-height: 360px;
    background: var(--black);
    animation: po-shimmer 1.8s ease-in-out infinite;
  }
  @keyframes po-shimmer {
    0%, 100% { background: var(--black); }
    50% { background: rgba(255,255,255,0.025); }
  }

  /* VEHICLE CARD */
  .po-vehicle-card {
    background: var(--black);
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: background 0.2s;
  }
  .po-vehicle-card:hover { background: rgba(255,255,255,0.02); }

  .po-img {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: rgba(255,255,255,0.04);
  }
  .po-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }
  .po-vehicle-card:hover .po-img img { transform: scale(1.04); }

  .po-badge {
    position: absolute;
    bottom: 10px;
    left: 10px;
    font-size: 8px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    padding: 4px 9px;
    background: rgba(0,0,0,0.75);
    color: rgba(168,168,168,0.65);
    backdrop-filter: blur(6px);
    font-family: inherit;
  }
  .po-badge--blindado {
    color: rgba(1,254,74,0.75);
    border: 1px solid rgba(1,254,74,0.18);
  }

  .po-info {
    padding: 20px 22px 24px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .po-name {
    font-size: 15px;
    font-weight: 400;
    color: var(--white);
    letter-spacing: -0.01em;
    line-height: 1.3;
    margin: 0 0 8px;
  }

  .po-meta {
    font-size: 10px;
    letter-spacing: 0.16em;
    color: rgba(168,168,168,0.4);
    text-transform: uppercase;
    margin: 0 0 16px;
    line-height: 1.6;
  }

  .po-price {
    font-size: 20px;
    font-weight: 300;
    color: var(--white);
    letter-spacing: -0.02em;
    margin: auto 0 14px;
  }

  .po-ficha {
    font-size: 9px;
    letter-spacing: 0.3em;
    color: rgba(168,168,168,0.32);
    text-transform: uppercase;
    transition: color 0.2s;
  }
  .po-vehicle-card:hover .po-ficha { color: rgba(168,168,168,0.75); }

  /* CTA CARD */
  .po-cta-card {
    background: rgba(255,255,255,0.015);
    padding: 32px 28px 36px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .po-cta-eyebrow {
    font-size: 9px;
    letter-spacing: 0.4em;
    color: rgba(168,168,168,0.25);
    text-transform: uppercase;
    margin: 0 0 auto;
  }

  .po-cta-heading {
    font-size: 22px;
    font-weight: 300;
    color: var(--white);
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 32px 0 12px;
  }

  .po-cta-desc {
    font-size: 12px;
    color: rgba(168,168,168,0.42);
    line-height: 1.8;
    margin: 0 0 28px;
  }

  .po-cta-link {
    font-size: 10px;
    letter-spacing: 0.28em;
    color: rgba(168,168,168,0.5);
    text-decoration: none;
    text-transform: uppercase;
    transition: color 0.2s;
  }
  .po-cta-link:hover { color: var(--white); }

  /* RESPONSIVE */
  @media (max-width: 1024px) {
    .po-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .po-inner { padding: 56px 24px; }
    .po-header { flex-direction: column; align-items: flex-start; gap: 18px; }
    .po-grid { grid-template-columns: 1fr; }
    .po-skeleton { min-height: 200px; }
  }
</style>
